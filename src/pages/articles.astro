---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleArchive from '../components/ArticleArchive.astro';
import { formatDate } from '../utils/formatDate';

const allArticles = await getCollection('articles');
const sorted = allArticles.sort(
  (a: CollectionEntry<'articles'>, b: CollectionEntry<'articles'>) =>
    b.data.date.valueOf() - a.data.date.valueOf()
);

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const articles = sorted.map((a) => ({
  ...a.data,
  date: formatDate(a.data.date),
  href: `${base}articles/${a.id}`,
}));
---

<BaseLayout title="All Articles">
  <ArticleArchive articles={articles} heading="All Articles" />
</BaseLayout>
