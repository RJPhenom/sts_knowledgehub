---
interface Props {
  title: string;
  subtitle?: string;
  image?: string;
  imageAlt?: string;
  readTime: number;
  date: string;
  href: string;
  category?: string;
}

const { title, subtitle, image, imageAlt, readTime, date, href, category } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<a href={href} class="article-list-item">
  {image && (
    <div class="list-thumb">
      <img src={`${base}${image.replace(/^\//, '')}`} alt={imageAlt ?? title} />
    </div>
  )}
  <div class="list-body">
    {category && <span class="list-category">{category}</span>}
    <h3 class="list-title">{title}</h3>
    {subtitle && <p class="list-subtitle">{subtitle}</p>}
    <div class="list-meta">
      <span class="read-dot"></span>
      <span class="read-time">{readTime} min</span>
      <span class="read-date">{date}</span>
    </div>
  </div>
</a>
