---
import '../styles/global.css';

interface Props {
  title?: string;
}
const { title = 'The Knowledge Hub' } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} — The Knowledge Hub</title>
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="brand">
          <h1 class="site-title">The<br />Knowledge<br />Hub</h1>
          <div class="brand-byline">
            <span class="by-text">By</span>
            <img src="/sts_logo.svg" alt="Semantic Technology Services" class="sts-logo" />
          </div>
        </a>

        <nav class="site-nav">
          <div class="nav-group">
            <a href="/about">About</a>
          </div>
          <div class="nav-group">
            <a href="/automation">Automation</a>
            <a href="/ai-news">AI News</a>
            <a href="/analytics">Analytics</a>
          </div>
          <div class="nav-group">
            <a href="/contact">Contact</a>
          </div>
        </nav>
      </div>
    </header>

    <main>
      <div class="container">
        <slot />
      </div>
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <p class="footer-copy">&copy; Semantic Technology Services 2026</p>
        <nav class="footer-nav">
          <a href="/about">About</a>
          <a href="/automation">Automation</a>
          <a href="/ai-news">AI News</a>
          <a href="/analytics">Analytics</a>
          <a href="/articles">All Articles</a>
          <a href="/contact">Contact</a>
        </nav>
      </div>
    </footer>
  </body>
</html>
