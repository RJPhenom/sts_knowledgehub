---
import '../styles/global.css';

interface Props {
  title?: string;
}
const { title = 'The Knowledge Hub' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} — The Knowledge Hub</title>
    <!-- Cloudflare Web Analytics -->
    <script defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "07bf9bdd99a8445a806a14b14f566b20"}'></script>
    <!-- End Cloudflare Web Analytics -->
  </head>
  <body>
    <div class="scroll-sentinel"></div>
    <header class="site-header">
      <div class="container header-inner">
        <a href={base} class="brand">
          <h1 class="site-title">
            <span class="title-full">The<br />Knowledge<br />Hub</span>
            <span class="title-short">TKH</span>
          </h1>
          <div class="brand-byline">
            <span class="by-text">By</span>
            <img src={`${base}sts_logo.svg`} alt="Semantic Technology Services" class="sts-logo" />
          </div>
        </a>

        <button class="burger-btn" aria-label="Toggle menu" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>

        <nav class="site-nav">
          <a href={`${base}automation`} class="nav-topic">Automation</a>
          <a href={`${base}ai-news`} class="nav-topic">AI News</a>
          <a href={`${base}analytics`} class="nav-topic">Analytics</a>
          <span class="nav-sep">|</span>
          <a href={`${base}about`}>About</a>
          <a href={`${base}contact`}>Contact</a>
          <a href="https://www.semantictechnologyservices.com" class="sts-link-btn" target="_blank" rel="noopener">
            <span class="sts-btn-label">Visit</span><img src={`${base}sts_logo_black.svg`} alt="Semantic Technology Services" class="sts-btn-logo" /> →
          </a>
        </nav>
      </div>
    </header>

    <main>
      <div class="container">
        <slot />
      </div>
    </main>

    <section class="cta-strip">
      <div class="container cta-strip-inner">
        <div class="cta-strip-text">
          <h2 class="cta-strip-heading">Looking for help with AI?</h2>
          <p class="cta-strip-body">Get in touch with one of our experts to help you stay ahead of the game in the world of AI Automation, Analytics and Acceleration.</p>
        </div>
        <a href="https://www.semantictechnologyservices.com" class="sts-link-btn" target="_blank" rel="noopener">
          <span class="sts-btn-label">Visit</span><img src={`${base}sts_logo_black.svg`} alt="Semantic Technology Services" class="sts-btn-logo" /> →
        </a>
      </div>
    </section>

    <footer class="site-footer">
      <div class="container footer-inner">
        <p class="footer-copy">&copy; Semantic Technology Services 2026</p>
        <nav class="footer-nav">
          <a href={`${base}about`}>About</a>
          <a href={`${base}automation`}>Automation</a>
          <a href={`${base}ai-news`}>AI News</a>
          <a href={`${base}analytics`}>Analytics</a>
          <a href={`${base}articles`}>All Articles</a>
          <a href={`${base}contact`}>Contact</a>
        </nav>
      </div>
    </footer>
  </body>
  <script>
    const header = document.querySelector('.site-header');
    const sentinel = document.querySelector('.scroll-sentinel');
    if (header && sentinel) {
      new IntersectionObserver(
        ([entry]) => header.classList.toggle('scrolled', !entry.isIntersecting),
        { threshold: 0 }
      ).observe(sentinel);
    }

    const burger = document.querySelector('.burger-btn');
    const nav = document.querySelector('.site-nav');
    if (burger && nav) {
      burger.addEventListener('click', () => {
        const open = header?.classList.toggle('menu-open');
        burger.setAttribute('aria-expanded', String(open));
      });
      nav.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          header?.classList.remove('menu-open');
          burger.setAttribute('aria-expanded', 'false');
        });
      });
    }
  </script>
</html>
