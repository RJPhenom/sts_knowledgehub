---
import '../styles/global.css';

interface Props {
  title?: string;
}
const { title = 'The Knowledge Hub' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} — The Knowledge Hub</title>
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a href={base} class="brand">
          <h1 class="site-title">The<br />Knowledge<br />Hub</h1>
          <div class="brand-byline">
            <span class="by-text">By</span>
            <img src={`${base}sts_logo.svg`} alt="Semantic Technology Services" class="sts-logo" />
          </div>
        </a>

        <nav class="site-nav">
          <div class="nav-group">
            <a href={`${base}about`}>About</a>
          </div>
          <div class="nav-group">
            <a href={`${base}automation`}>Automation</a>
            <a href={`${base}ai-news`}>AI News</a>
            <a href={`${base}analytics`}>Analytics</a>
          </div>
          <div class="nav-group">
            <a href={`${base}contact`}>Contact</a>
          </div>
        </nav>
      </div>
    </header>

    <main>
      <div class="container">
        <slot />
      </div>
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <p class="footer-copy">&copy; Semantic Technology Services 2026</p>
        <nav class="footer-nav">
          <a href={`${base}about`}>About</a>
          <a href={`${base}automation`}>Automation</a>
          <a href={`${base}ai-news`}>AI News</a>
          <a href={`${base}analytics`}>Analytics</a>
          <a href={`${base}articles`}>All Articles</a>
          <a href={`${base}contact`}>Contact</a>
        </nav>
      </div>
    </footer>
  </body>
</html>
